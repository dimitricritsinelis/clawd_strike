{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bazaar Slice Map Spec",
  "type": "object",
  "required": [
    "metadata",
    "global_dimensions",
    "zones"
  ],
  "properties": {
    "metadata": {
      "type": "object"
    },
    "global_dimensions": {
      "type": "object",
      "properties": {
        "wall_thickness_default": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "wall_details": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "seed": {
          "type": "number"
        },
        "style": {
          "type": "string",
          "enum": [
            "bazaar"
          ]
        },
        "density": {
          "type": "number"
        },
        "maxProtrusion": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "facade_overrides": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "zoneId",
              "face",
              "preset"
            ],
            "properties": {
              "zoneId": {
                "type": "string"
              },
              "face": {
                "type": "string",
                "enum": [
                  "north",
                  "south",
                  "east",
                  "west"
                ]
              },
              "preset": {
                "type": "string",
                "enum": [
                  "merchant_rhythm",
                  "merchant_hero_stack",
                  "residential_quiet",
                  "residential_balcony_stack",
                  "spawn_courtyard_landmark",
                  "service_blank"
                ]
              }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "lanes": {
      "type": "object"
    },
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "rect"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "rect": {
            "type": "object",
            "required": [
              "x",
              "y",
              "w",
              "h"
            ],
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              },
              "w": {
                "type": "number"
              },
              "h": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}

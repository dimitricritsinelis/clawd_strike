{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bazaar Slice Map Spec",
  "type": "object",
  "required": [
    "metadata",
    "global_dimensions",
    "zones"
  ],
  "properties": {
    "metadata": {
      "type": "object"
    },
    "global_dimensions": {
      "type": "object",
      "properties": {
        "wall_thickness_default": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "wall_details": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "seed": {
          "type": "number"
        },
        "style": {
          "type": "string",
          "enum": [
            "bazaar"
          ]
        },
        "density": {
          "type": "number"
        },
        "maxProtrusion": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "facade_overrides": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "zoneId",
              "face",
              "preset"
            ],
            "properties": {
              "zoneId": {
                "type": "string"
              },
              "face": {
                "type": "string",
                "enum": [
                  "north",
                  "south",
                  "east",
                  "west"
                ]
              },
              "preset": {
                "type": "string",
                "enum": [
                  "merchant_rhythm",
                  "merchant_hero_stack",
                  "residential_quiet",
                  "residential_balcony_stack",
                  "spawn_courtyard_landmark",
                  "spawn_gate_brick_backdrop",
                  "service_blank"
                ]
              }
            }
          }
        },
        "window_layout_overrides": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "zoneId",
              "face",
              "segmentOrdinal",
              "windows"
            ],
            "properties": {
              "zoneId": {
                "type": "string"
              },
              "face": {
                "type": "string",
                "enum": [
                  "north",
                  "south",
                  "east",
                  "west"
                ]
              },
              "segmentOrdinal": {
                "type": "integer",
                "minimum": 1
              },
              "windows": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": [
                    "centerS",
                    "sillY",
                    "width",
                    "height",
                    "headShape",
                    "glassStyle"
                  ],
                  "properties": {
                    "centerS": {
                      "type": "number"
                    },
                    "sillY": {
                      "type": "number"
                    },
                    "width": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "height": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "headShape": {
                      "type": "string",
                      "enum": [
                        "rect",
                        "pointed_arch"
                      ]
                    },
                    "glassStyle": {
                      "type": "string",
                      "enum": [
                        "stained_glass_bright",
                        "stained_glass_dim"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "layout_reference": {
      "type": "object",
      "properties": {
        "zone_aliases": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "areaId",
              "zoneId",
              "label",
              "shortLabel"
            ],
            "properties": {
              "areaId": {
                "type": "string"
              },
              "zoneId": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "shortLabel": {
                "type": "string"
              },
              "humanLabel": {
                "type": "string"
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        "building_frontages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "buildingId",
              "zoneId",
              "face",
              "label",
              "shortLabel"
            ],
            "properties": {
              "buildingId": {
                "type": "string"
              },
              "zoneId": {
                "type": "string"
              },
              "face": {
                "type": "string",
                "enum": [
                  "north",
                  "south",
                  "east",
                  "west"
                ]
              },
              "label": {
                "type": "string"
              },
              "shortLabel": {
                "type": "string"
              },
              "humanLabel": {
                "type": "string"
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        "custom_callouts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "calloutId",
              "label",
              "shortLabel",
              "spawnZoneId",
              "hallZoneId",
              "connectorZoneId",
              "spawnFace"
            ],
            "properties": {
              "calloutId": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "shortLabel": {
                "type": "string"
              },
              "humanLabel": {
                "type": "string"
              },
              "spawnZoneId": {
                "type": "string"
              },
              "hallZoneId": {
                "type": "string"
              },
              "connectorZoneId": {
                "type": "string"
              },
              "spawnFace": {
                "type": "string",
                "enum": [
                  "east",
                  "west"
                ]
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "lanes": {
      "type": "object"
    },
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "rect"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "rect": {
            "type": "object",
            "required": [
              "x",
              "y",
              "w",
              "h"
            ],
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              },
              "w": {
                "type": "number"
              },
              "h": {
                "type": "number"
              }
            }
          }
        }
      }
    },
    "anchors": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}

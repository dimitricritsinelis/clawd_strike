{
  "name": "@clawd-strike/client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "gen:maps": "node scripts/gen-map-runtime.mjs",
    "gen:layout-reference": "node scripts/gen-layout-reference.mjs",
    "assets:loading-screen": "node scripts/optimize-loading-screen-assets.mjs",
    "review:shot-pair": "node scripts/review-shot-pair.mjs",
    "capture:shots": "node scripts/capture-map-shots.mjs",
    "bot:smoke": "node scripts/bot-intelligence-smoke.mjs",
    "smoke:headshot-kill-perf": "node scripts/headshot-kill-perf-smoke.mjs",
    "smoke:orb-scaling-perf": "node scripts/orb-scaling-perf-smoke.mjs",
    "smoke:loading-screen-perf": "node scripts/loading-screen-perf-smoke.mjs",
    "smoke:wave-ammo-reset": "node scripts/wave-ammo-reset-smoke.mjs",
    "smoke:no-context": "node scripts/no-context-agent-smoke.mjs",
    "verify:skills-contract": "node scripts/verify-skills-contract.mjs",
    "verify:loading-screen-assets": "node scripts/verify-loading-screen-assets.mjs",
    "qa:completion": "node scripts/qa-completion-gate.mjs",
    "smoke:agent": "node scripts/agent-smoke-runner.mjs",
    "smoke:game": "playwright test playwright/runtime-boot.spec.ts playwright/agent-traversal.spec.ts playwright/death-restart.spec.ts",
    "qa:autonomous": "pnpm qa:completion",
    "predev": "pnpm gen:maps",
    "prebuild": "pnpm gen:maps",
    "prepreview": "pnpm gen:maps",
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:playwright": "pnpm test:playwright:full",
    "test:playwright:full": "playwright test",
    "test:playwright:headed": "playwright test --headed",
    "test:playwright:pointer-lock": "PW_POINTER_LOCK=1 playwright test playwright/manual-pointer-lock.spec.ts --headed --workers=1"
  },
  "dependencies": {
    "three": "^0.181.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/three": "^0.181.0",
    "ffmpeg-static": "^5.3.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
